rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Lee el documento del usuario en Firestore.
    // Solo se usa como fallback para isTeacher() mientras los claims de rol
    // no estén asignados a usuarios existentes. isAdmin() NO lo usa.
    function getCurrentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // isAdmin usa SOLO el custom claim (asignado por el backend — no manipulable por el cliente)
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    
    // isTeacher: primero verifica claim (usuarios nuevos), luego fallback a Firestore (usuarios existentes)
    function isTeacher() {
      return isAuthenticated() && (
        request.auth.token.teacher == true ||
        getCurrentUser().role == 'Profesor' ||
        getCurrentUser().rol == 'profesor' ||
        getCurrentUser().rol == 'teacher'
      );
    }

    // Garantiza que los campos de rol no cambien en una auto-actualización
    function roleFieldsUnchanged() {
      return request.resource.data.role == resource.data.role &&
             request.resource.data.rol  == resource.data.rol;
    }
    
    match /users/{userId} {
      // FIX §1.2: estudiantes solo pueden leer su propio doc; profesores y admins pueden leer cualquiera
      allow read: if request.auth.uid == userId || isTeacher() || isAdmin();
      allow create: if isAdmin();
      // FIX §1.3: un usuario actualizando su propio doc NO puede cambiar los campos de rol
      allow update: if isAdmin() ||
                       (request.auth.uid == userId && roleFieldsUnchanged());
      allow delete: if isAdmin();
      
      match /notifications/{notifId} {
        allow read, write: if request.auth.uid == userId;
      }
      
      match /announcementsRead/{annId} {
        allow read, write: if request.auth.uid == userId;
      }
      
      match /progress/{docId} {
        allow read, write: if request.auth.uid == userId || isTeacher() || isAdmin();
      }
      
      match /earnedBadges/{badgeId} {
        allow read: if request.auth.uid == userId;
        allow write: if false;
      }
    }
    
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update: if isAuthenticated() && (resource.data.teacherId == request.auth.uid || resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.teacherId == request.auth.uid || resource.data.ownerId == request.auth.uid || isAdmin());
      
      match /posts/{postId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
        
        match /replies/{replyId} {
          allow read: if isAuthenticated();
          allow create: if isAuthenticated();
          allow update, delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
        }
      }
      
      match /assignments/{assignmentId} {
        allow read: if isAuthenticated();
        allow write: if isTeacher() || isAdmin();
        
        match /submissions/{studentId} {
          allow read: if isAuthenticated();
          allow create, update: if isAuthenticated();
        }
      }
    }
    
    match /chats/{chatId} {
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated();
      
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
    }
    
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /modules/{moduleId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
        
        match /lessons/{lessonId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin();
          
          match /comments/{commentId} {
            allow read: if isAuthenticated();
            allow create: if isAuthenticated();
            allow update, delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
          }
        }
      }
    }
    
    match /labGames/{gameId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /badges/{badgeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if isAuthenticated() && (resource.data.teacherId == request.auth.uid || isAdmin());
      
      match /submissions/{submissionId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated();
      }
    }
    
    match /lecciones/{leccionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }
    
    match /grades/{gradeId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if isAuthenticated() && (resource.data.teacherId == request.auth.uid || isAdmin());
    }

    match /gradesParciales/{docId} {
      allow read: if isAuthenticated();
      allow write: if isTeacher() || isAdmin();
    }

    match /attendance/{docId} {
      allow read: if isTeacher() || isAdmin();
      allow write: if isTeacher() || isAdmin();
    }
    
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update: if isAdmin();
    }
    
    match /passwordResetRequests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update: if isAdmin();
      allow delete: if false;
    }
    
    match /userPasswords/{userId} {
      allow write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAdmin();
    }
  }
}
